# Cloudflare Pages applies these to the static site (prod + *.pages.dev preview).
# https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  X-Frame-Options: DENY
  Content-Security-Policy: default-src 'self'; script-src 'self' https://challenges.cloudflare.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://swarley-club-dev.mateoblackman.workers.dev; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; object-src 'none'

# The moderation page is gated by a bearer token; also keep it out of indexes.
/admin.html
  X-Robots-Tag: noindex

# Hashed/static image assets — cache hard at the edge and in the browser.
/images/*
  Cache-Control: public, max-age=31536000, immutable
